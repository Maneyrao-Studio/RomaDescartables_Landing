# ============================================
# Roma Descartables - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# Next.js will automatically load variables from .env.local
# ============================================

# --------------------------------------------
# API Configuration
# --------------------------------------------
# Base URL for the backend API
# This URL is used to fetch product data, categories, and other dynamic content
# Must be accessible from the client-side (hence NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=https://backend-roma-production.up.railway.app

# Example for local development:
# NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --------------------------------------------
# Notes:
# --------------------------------------------
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Never commit sensitive credentials or API keys without NEXT_PUBLIC_ prefix
# - This project uses the Backend API to fetch products from /public/products endpoint
# - The API client is defined in lib/api-client.ts
# ============================================
